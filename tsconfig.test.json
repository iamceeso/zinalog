{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "tests/**/*.ts",
    "lib/db.ts",
    "lib/auth.ts",
    "lib/admin-rate-limit.ts",
    "lib/email.ts"
  ],
  "exclude": ["node_modules", ".next", ".test-dist"]
}
